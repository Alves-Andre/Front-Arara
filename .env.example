// .env.example

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Map Configuration
NEXT_PUBLIC_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png

# Auth
NEXT_PUBLIC_AUTH_TOKEN_KEY=authToken
NEXT_PUBLIC_AUTH_TOKEN_EXPIRES_IN=3600

# GIS / Geospatial
NEXT_PUBLIC_DEFAULT_LAT=-15.8267
NEXT_PUBLIC_DEFAULT_LNG=-48.0
NEXT_PUBLIC_DEFAULT_ZOOM=10

# Features
NEXT_PUBLIC_ENABLE_SATELLITE_IMAGERY=true
NEXT_PUBLIC_ENABLE_ANALYSIS_TOOLS=true
NEXT_PUBLIC_ENABLE_REPORTS=true

# Analytics (opcional)
NEXT_PUBLIC_GA_ID=
